{
  "name": "simba-backend",
  "version": "1.0.0",
  "description": "Simba Supermarket REST API — Kigali, Rwanda",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:schema": "psql $DATABASE_URL -f src/db/schema.sql",
    "db:seed": "node scripts/seed.js",
    "db:setup": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
